# ============================================
# Database
# ============================================
POSTGRES_DB=cz_migration_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_PORT=5432

# ============================================
# Redis
# ============================================
REDIS_PORT=6379

# ============================================
# Backend (Spring Boot)
# ============================================
SPRING_PROFILES_ACTIVE=dev
BACKEND_PORT=8080

# ============================================
# Frontend (Nuxt.js 3)
# ============================================
FRONTEND_PORT=3000

# ============================================
# Auth Mock (Express ALB+Okta OIDC)
# ============================================
AUTH_MOCK_PORT=8180
JWT_SECRET=dev-mock-secret
JWT_ISSUER=https://mock-okta.example.com

# ============================================
# Dev Authentication
# ============================================
DEV_AUTH_ENABLED=true
